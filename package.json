{
  "name": "familie-ba-sak-frontend",
  "type": "module",
  "version": "0.0.1",
  "main": "backend/server.js",
  "repository": "https://github.com/navikt/familie-ba-sak-frontend.git",
  "author": "Team BAKS",
  "license": "MIT",
  "scripts": {
    "start": "yarn start:backend:prod",
    "start:dev": "yarn start:lokalt-mot-preprod",
    "start-env": "yarn miljøvariabler && yarn build:backend && ENV=\"$ENV\" yarn start:backend:dev",
    "start:lokal": "ENV=lokal yarn start-env",
    "start:hybrid": "ENV=hybrid yarn start-env",
    "start:lokalt-mot-preprod": "ENV=lokalt-mot-preprod yarn start-env",
    "start:backend:dev": "NODE_ENV=development node dist_backend/server.js",
    "start:backend:prod": "NODE_ENV=production ENV=prod node dist_backend/server.js",
    "miljøvariabler": "./hent-og-lagre-miljøvariabler.sh",
    "build": "yarn build:prod",
    "build:dev": "NODE_ENV=development yarn build:backend && yarn build:frontend --mode lokalt-mot-preprod",
    "build:preprod": "NODE_ENV=production yarn build:backend && yarn build:frontend --mode preprod",
    "build:prod": "NODE_ENV=production yarn build:backend && yarn build:frontend --mode prod",
    "build:backend": "tsc -p src/backend/tsconfig.json",
    "build:frontend": "vite build src/frontend",
    "test": "vitest",
    "lint": "eslint './src/**/*.{js,ts,tsx}'",
    "lint:fix": "eslint './src/**/*.{js,ts,tsx}' --fix",
    "prettier": "prettier --check './src/**/*.{js,jsx,ts,tsx,json,css}'",
    "prettier:fix": "prettier --write './src/**/*.{js,jsx,ts,tsx,json,css}'",
    "prepare": "husky",
    "typecheck": "tsc --noEmit -p src/backend/tsconfig.json && tsc --noEmit -p src/frontend/tsconfig.json",
    "validate": "yarn typecheck && yarn lint && yarn prettier"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=150"
    ],
    "src/**/*.{js,jsx,ts,tsx,css}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@dotenvx/dotenvx": "1.73.1",
    "@grafana/faro-web-sdk": "2.7.1",
    "@navikt/aksel-icons": "8.13.1",
    "@navikt/ds-css": "8.13.1",
    "@navikt/ds-react": "8.13.1",
    "@navikt/ds-tokens": "8.13.1",
    "@navikt/familie-backend": "10.1.24",
    "@navikt/familie-form-elements": "22.0.1",
    "@navikt/familie-header": "17.0.3",
    "@navikt/familie-http": "8.0.22",
    "@navikt/familie-ikoner": "9.1.4",
    "@navikt/familie-logging": "7.0.7",
    "@navikt/familie-skjema": "8.2.48",
    "@navikt/familie-tidslinje": "11.0.2",
    "@navikt/familie-typer": "8.0.5",
    "@navikt/flagg-ikoner": "14.0.3",
    "@navikt/fnrvalidator": "2.2.1",
    "@navikt/land-verktoy": "14.0.3",
    "@sentry/browser": "10.58.0",
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-query-devtools": "5.101.1",
    "@tanstack/react-virtual": "3.14.3",
    "axios": "1.18.1",
    "classnames": "2.5.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "dayjs": "1.11.21",
    "deep-equal": "2.2.3",
    "express": "5.2.1",
    "http-proxy-middleware": "4.1.1",
    "lodash": "4.18.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.79.0",
    "react-router": "8.0.1",
    "styled-components": "6.4.3",
    "tslib": "2.8.1",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@axe-core/react": "4.11.3",
    "@eslint/js": "9.39.4",
    "@sentry/vite-plugin": "5.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/deep-equal": "1.0.4",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "msw": "2.14.6",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
